{"id": "find_large_files", "request": "find files larger than 1KB in the current directory tree", "setup": ["mkdir -p subdir", "dd if=/dev/zero of=big.txt bs=2048 count=1 2>/dev/null", "touch small.txt", "dd if=/dev/zero of=subdir/medium.txt bs=1500 count=1 2>/dev/null"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "big.txt"}, {"type": "stdout_contains", "value": "medium.txt"}, {"type": "stdout_not_contains", "value": "small.txt"}]}, "tags": ["file_ops", "find"]}
{"id": "list_hidden_files", "request": "list all files including hidden ones in the current directory", "setup": ["touch .hidden_file", "touch visible_file", "mkdir .hidden_dir"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": ".hidden_file"}, {"type": "stdout_contains", "value": "visible_file"}]}, "tags": ["file_ops", "ls"]}
{"id": "create_nested_dirs", "request": "create the directory structure project/src/main/java", "setup": [], "verify": {"type": "dir_exists", "path": "project/src/main/java"}, "tags": ["file_ops", "mkdir"]}
{"id": "copy_with_extension", "request": "copy all .txt files to a directory called backup", "setup": ["mkdir backup", "echo hello > a.txt", "echo world > b.txt", "echo skip > c.log"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "backup/a.txt"}, {"type": "file_exists", "path": "backup/b.txt"}, {"type": "file_not_exists", "path": "backup/c.log"}]}, "tags": ["file_ops", "cp"]}
{"id": "rename_file", "request": "rename old_name.txt to new_name.txt", "setup": ["echo content > old_name.txt"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "new_name.txt"}, {"type": "file_not_exists", "path": "old_name.txt"}, {"type": "file_contains", "path": "new_name.txt", "value": "content"}]}, "tags": ["file_ops", "mv"]}
{"id": "touch_multiple_files", "request": "create empty files called a.txt, b.txt, and c.txt", "setup": [], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "a.txt"}, {"type": "file_exists", "path": "b.txt"}, {"type": "file_exists", "path": "c.txt"}]}, "tags": ["file_ops", "touch"]}
{"id": "find_by_name", "request": "find all files named '*.log' under the current directory", "setup": ["mkdir -p sub/deep", "touch app.log", "touch sub/error.log", "touch sub/deep/trace.log", "touch readme.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "app.log"}, {"type": "stdout_contains", "value": "error.log"}, {"type": "stdout_contains", "value": "trace.log"}, {"type": "stdout_not_contains", "value": "readme.txt"}]}, "tags": ["file_ops", "find"]}
{"id": "disk_usage_summary", "request": "show disk usage of each subdirectory summarized", "setup": ["mkdir -p dir_a dir_b", "dd if=/dev/zero of=dir_a/f.bin bs=4096 count=1 2>/dev/null", "dd if=/dev/zero of=dir_b/f.bin bs=8192 count=1 2>/dev/null"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "dir_a"}, {"type": "stdout_contains", "value": "dir_b"}]}, "tags": ["file_ops", "du"]}
{"id": "delete_by_extension", "request": "delete all .tmp files in the current directory", "setup": ["touch keep.txt", "touch a.tmp", "touch b.tmp"], "verify": {"type": "compound", "checks": [{"type": "file_not_exists", "path": "a.tmp"}, {"type": "file_not_exists", "path": "b.tmp"}, {"type": "file_exists", "path": "keep.txt"}]}, "tags": ["file_ops", "rm"]}
{"id": "list_sorted_by_size", "request": "list files sorted by size, largest first", "setup": ["dd if=/dev/zero of=big.dat bs=4096 count=1 2>/dev/null", "dd if=/dev/zero of=med.dat bs=2048 count=1 2>/dev/null", "touch tiny.dat"], "verify": {"type": "stdout_match", "pattern": "big.*med|big.*tiny"}, "tags": ["file_ops", "ls"]}
{"id": "grep_pattern", "request": "search for lines containing 'ERROR' in app.log", "setup": ["printf 'INFO start\\nERROR disk full\\nINFO ok\\nERROR timeout\\n' > app.log"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "ERROR disk full"}, {"type": "stdout_contains", "value": "ERROR timeout"}, {"type": "stdout_not_contains", "value": "INFO start"}]}, "tags": ["text", "grep"]}
{"id": "count_lines", "request": "count the number of lines in data.txt", "setup": ["printf 'a\\nb\\nc\\nd\\ne\\n' > data.txt"], "verify": {"type": "stdout_match", "pattern": "(^| )5( |$)"}, "tags": ["text", "wc"]}
{"id": "sort_numerically", "request": "sort the numbers in numbers.txt in numeric order", "setup": ["printf '10\\n2\\n33\\n1\\n5\\n' > numbers.txt"], "verify": {"type": "stdout_match", "pattern": "1.*2.*5.*10.*33"}, "tags": ["text", "sort"]}
{"id": "head_first_three", "request": "show the first 3 lines of file.txt", "setup": ["printf 'line1\\nline2\\nline3\\nline4\\nline5\\n' > file.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "line1"}, {"type": "stdout_contains", "value": "line3"}, {"type": "stdout_not_contains", "value": "line4"}]}, "tags": ["text", "head"]}
{"id": "tail_last_two", "request": "show the last 2 lines of log.txt", "setup": ["printf 'old1\\nold2\\nold3\\nrecent1\\nrecent2\\n' > log.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "recent1"}, {"type": "stdout_contains", "value": "recent2"}, {"type": "stdout_not_contains", "value": "old1"}]}, "tags": ["text", "tail"]}
{"id": "unique_lines", "request": "show only unique lines from data.txt removing duplicates", "setup": ["printf 'apple\\nbanana\\napple\\ncherry\\nbanana\\n' > data.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "cherry"}, {"type": "stdout_line_count", "op": "eq", "value": 3}]}, "tags": ["text", "sort", "uniq"]}
{"id": "replace_string_in_file", "request": "replace all occurrences of 'foo' with 'bar' in config.txt and save in-place", "setup": ["printf 'foo=1\\nbaz=2\\nfoo=3\\n' > config.txt"], "verify": {"type": "compound", "checks": [{"type": "file_contains", "path": "config.txt", "value": "bar=1"}, {"type": "file_contains", "path": "config.txt", "value": "bar=3"}]}, "tags": ["text", "sed"]}
{"id": "extract_column", "request": "print the second column of data.csv using comma as delimiter", "setup": ["printf 'name,age,city\\nalice,30,NYC\\nbob,25,LA\\n' > data.csv"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "30"}, {"type": "stdout_contains", "value": "25"}]}, "tags": ["text", "awk", "cut"]}
{"id": "grep_count", "request": "count how many lines in access.log contain '404'", "setup": ["printf 'GET /home 200\\nGET /missing 404\\nGET /about 200\\nGET /old 404\\nGET /gone 404\\n' > access.log"], "verify": {"type": "stdout_match", "pattern": "(^| )3( |$)"}, "tags": ["text", "grep"]}
{"id": "reverse_file_lines", "request": "print the lines of data.txt in reverse order", "setup": ["printf 'first\\nsecond\\nthird\\n' > data.txt"], "verify": {"type": "stdout_match", "pattern": "third.*second.*first"}, "tags": ["text", "tac"]}
{"id": "git_log_oneline", "request": "show the last 3 commits in one-line format", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "touch f1 && git add f1 && git commit -q -m 'first'", "touch f2 && git add f2 && git commit -q -m 'second'", "touch f3 && git add f3 && git commit -q -m 'third'", "touch f4 && git add f4 && git commit -q -m 'fourth'"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "fourth"}, {"type": "stdout_contains", "value": "third"}, {"type": "stdout_contains", "value": "second"}, {"type": "stdout_not_contains", "value": "first"}]}, "tags": ["git", "log"]}
{"id": "git_create_branch", "request": "create a new branch called feature/login", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "touch init && git add init && git commit -q -m 'init'"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_exists", "path": ".git/refs/heads/feature/login"}]}, "tags": ["git", "branch"]}
{"id": "git_show_status", "request": "show which files have been modified or are untracked", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "echo v1 > tracked.txt && git add tracked.txt && git commit -q -m 'init'", "echo v2 > tracked.txt", "touch untracked.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "tracked.txt"}, {"type": "stdout_contains", "value": "untracked.txt"}]}, "tags": ["git", "status"]}
{"id": "git_diff_staged", "request": "show the diff of staged changes", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "echo original > file.txt && git add file.txt && git commit -q -m 'init'", "echo modified > file.txt && git add file.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "original"}, {"type": "stdout_contains", "value": "modified"}]}, "tags": ["git", "diff"]}
{"id": "git_stash_changes", "request": "stash the current changes", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "echo v1 > file.txt && git add file.txt && git commit -q -m 'init'", "echo v2 > file.txt"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_contains", "path": "file.txt", "value": "v1"}]}, "tags": ["git", "stash"]}
{"id": "git_list_branches", "request": "list all local branches", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "touch init && git add init && git commit -q -m 'init'", "git branch dev", "git branch staging"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "dev"}, {"type": "stdout_contains", "value": "staging"}]}, "tags": ["git", "branch"]}
{"id": "git_commit_all", "request": "commit all changes with message 'update config'", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "echo v1 > cfg.txt && git add cfg.txt && git commit -q -m 'init'", "echo v2 > cfg.txt"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_exists", "path": ".git/COMMIT_EDITMSG"}]}, "tags": ["git", "commit"]}
{"id": "show_running_processes", "request": "show all running processes", "setup": [], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "stdout_line_count", "op": "ge", "value": 2}]}, "tags": ["process", "ps"]}
{"id": "show_os_info", "request": "show the operating system name and version", "setup": [], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "stdout_match", "pattern": "[Ll]inux|Darwin|BSD|macOS|Windows"}]}, "tags": ["system", "uname"]}
{"id": "show_disk_free", "request": "show free disk space in human readable format", "setup": [], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "stdout_match", "pattern": "[GMKT]"}]}, "tags": ["system", "df"]}
{"id": "show_env_variable", "request": "print the value of the HOME environment variable", "setup": [], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "stdout_match", "pattern": "^/"}]}, "tags": ["system", "env"]}
{"id": "current_datetime", "request": "show the current date and time", "setup": [], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "stdout_match", "pattern": "20[0-9]{2}"}]}, "tags": ["system", "date"]}
{"id": "tar_create", "request": "create a tar.gz archive called backup.tar.gz of the src directory", "setup": ["mkdir -p src", "echo code > src/main.py", "echo test > src/test.py"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "backup.tar.gz"}, {"type": "exit_code", "value": 0}]}, "tags": ["compression", "tar"]}
{"id": "tar_extract", "request": "extract archive.tar.gz into the current directory", "setup": ["mkdir -p orig", "echo data > orig/file.txt", "tar czf archive.tar.gz orig", "rm -rf orig"], "verify": {"type": "file_contains", "path": "orig/file.txt", "value": "data"}, "tags": ["compression", "tar"]}
{"id": "gzip_file", "request": "compress data.txt with gzip", "setup": ["echo payload > data.txt"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "data.txt.gz"}, {"type": "file_not_exists", "path": "data.txt"}]}, "tags": ["compression", "gzip"]}
{"id": "zip_directory", "request": "create a zip file called project.zip containing the docs directory", "setup": ["mkdir -p docs", "echo readme > docs/README.md", "echo license > docs/LICENSE"], "verify": {"type": "file_exists", "path": "project.zip"}, "tags": ["compression", "zip"]}
{"id": "tar_list_contents", "request": "list the contents of archive.tar.gz without extracting", "setup": ["mkdir -p pkg", "echo a > pkg/one.txt", "echo b > pkg/two.txt", "tar czf archive.tar.gz pkg"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "one.txt"}, {"type": "stdout_contains", "value": "two.txt"}]}, "tags": ["compression", "tar"]}
{"id": "make_executable", "request": "make script.sh executable", "setup": ["echo '#!/bin/sh' > script.sh"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_executable", "path": "script.sh"}]}, "tags": ["permissions", "chmod"]}
{"id": "set_readonly", "request": "make secret.txt read-only by removing write permission for everyone", "setup": ["echo topsecret > secret.txt"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_not_writable", "path": "secret.txt"}]}, "tags": ["permissions", "chmod"]}
{"id": "recursive_permission", "request": "recursively set all files in the config directory to permissions 644", "setup": ["mkdir -p config/sub", "touch config/a.cfg", "touch config/sub/b.cfg", "chmod 777 config/a.cfg config/sub/b.cfg"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_mode", "path": "config/a.cfg", "mode": "644"}, {"type": "file_mode", "path": "config/sub/b.cfg", "mode": "644"}]}, "tags": ["permissions", "chmod"]}
{"id": "pipe_grep_count", "request": "count how many .txt files are in the current directory tree", "setup": ["touch a.txt", "touch b.txt", "mkdir sub", "touch sub/c.txt", "touch d.log"], "verify": {"type": "stdout_match", "pattern": "(^| )3( |$)"}, "tags": ["pipe", "find", "wc"]}
{"id": "pipe_sort_unique_count", "request": "count the number of unique words in words.txt", "setup": ["printf 'apple\\nbanana\\napple\\ncherry\\nbanana\\napple\\n' > words.txt"], "verify": {"type": "stdout_match", "pattern": "(^| )3( |$)"}, "tags": ["pipe", "sort", "uniq", "wc"]}
{"id": "pipe_find_and_grep", "request": "find all .py files that contain the word 'import'", "setup": ["echo 'import os' > a.py", "echo 'x = 1' > b.py", "echo 'import sys' > c.py", "echo 'nothing' > d.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "a.py"}, {"type": "stdout_contains", "value": "c.py"}, {"type": "stdout_not_contains", "value": "b.py"}, {"type": "stdout_not_contains", "value": "d.txt"}]}, "tags": ["pipe", "find", "grep"]}
{"id": "pipe_top_disk_users", "request": "show the top 3 largest files in the current directory", "setup": ["dd if=/dev/zero of=huge.bin bs=8192 count=1 2>/dev/null", "dd if=/dev/zero of=big.bin bs=4096 count=1 2>/dev/null", "dd if=/dev/zero of=med.bin bs=2048 count=1 2>/dev/null", "touch tiny.bin"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "huge.bin"}, {"type": "stdout_contains", "value": "big.bin"}]}, "tags": ["pipe", "ls", "sort"]}
{"id": "spaces_in_filename", "request": "create a file called 'my important document.txt' containing 'hello world'", "setup": [], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "my important document.txt"}, {"type": "file_contains", "path": "my important document.txt", "value": "hello world"}]}, "tags": ["edge_case", "quoting"]}
{"id": "special_chars_grep", "request": "search for the literal string '$HOME' in env.txt", "setup": ["printf 'path=/usr/bin\\nvar=$HOME/docs\\nother=value\\n' > env.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "$HOME"}, {"type": "stdout_not_contains", "value": "path="}]}, "tags": ["edge_case", "quoting", "grep"]}
{"id": "list_only_directories", "request": "list only directories (not files) in the current path", "setup": ["mkdir dir_a", "mkdir dir_b", "touch file_a.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "dir_a"}, {"type": "stdout_contains", "value": "dir_b"}, {"type": "stdout_not_contains", "value": "file_a.txt"}]}, "tags": ["edge_case", "ls", "find"]}
{"id": "jq_extract_field", "request": "extract the name field from data.json", "setup": ["printf '{\"name\":\"alice\",\"age\":30,\"city\":\"NYC\"}' > data.json"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "alice"}, {"type": "stdout_not_contains", "value": "30"}]}, "tags": ["json", "jq"]}
{"id": "jq_filter_array", "request": "list items with status 'active' from items.json", "setup": ["printf '[{\"name\":\"alpha\",\"status\":\"active\"},{\"name\":\"beta\",\"status\":\"inactive\"},{\"name\":\"gamma\",\"status\":\"active\"}]' > items.json"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "alpha"}, {"type": "stdout_contains", "value": "gamma"}, {"type": "stdout_not_contains", "value": "beta"}]}, "tags": ["json", "jq"]}
{"id": "jq_count_items", "request": "count how many items are in the array in data.json", "setup": ["printf '[1,2,3,4,5]' > data.json"], "verify": {"type": "stdout_match", "pattern": "(^| )5( |$)"}, "tags": ["json", "jq"]}
{"id": "xargs_delete", "request": "find all .bak files and delete them", "setup": ["touch a.bak", "touch b.bak", "touch c.bak", "touch keep.txt"], "verify": {"type": "compound", "checks": [{"type": "file_not_exists", "path": "a.bak"}, {"type": "file_not_exists", "path": "b.bak"}, {"type": "file_not_exists", "path": "c.bak"}, {"type": "file_exists", "path": "keep.txt"}]}, "tags": ["batch", "xargs", "find"]}
{"id": "batch_rename_ext", "request": "rename all .txt files to .md", "setup": ["echo aaa > a.txt", "echo bbb > b.txt"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "a.md"}, {"type": "file_exists", "path": "b.md"}, {"type": "file_not_exists", "path": "a.txt"}, {"type": "file_not_exists", "path": "b.txt"}]}, "tags": ["batch", "rename"]}
{"id": "parallel_gzip", "request": "gzip all .log files in the current directory", "setup": ["echo log1 > a.log", "echo log2 > b.log", "echo keep > c.txt"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "a.log.gz"}, {"type": "file_exists", "path": "b.log.gz"}, {"type": "file_exists", "path": "c.txt"}, {"type": "file_not_exists", "path": "a.log"}, {"type": "file_not_exists", "path": "b.log"}]}, "tags": ["batch", "gzip"]}
{"id": "git_tag_version", "request": "create a tag called v1.0 on the current commit", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "touch init && git add init && git commit -q -m 'init'"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_exists", "path": ".git/refs/tags/v1.0"}]}, "tags": ["git", "tag"]}
{"id": "git_cherry_pick", "request": "cherry-pick the latest commit from branch feature", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "echo base > base.txt && git add base.txt && git commit -q -m 'base'", "git checkout -q -b feature", "echo feat > feat.txt && git add feat.txt && git commit -q -m 'add feature'", "git checkout -q master"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_exists", "path": "feat.txt"}]}, "tags": ["git", "cherry-pick"]}
{"id": "git_undo_commit", "request": "undo the last commit but keep the changes", "setup": ["git init -q", "git config user.email test@test.com", "git config user.name Test", "echo v1 > file.txt && git add file.txt && git commit -q -m 'first'", "echo v2 > file.txt && git add file.txt && git commit -q -m 'second'"], "verify": {"type": "compound", "checks": [{"type": "exit_code", "value": 0}, {"type": "file_contains", "path": "file.txt", "value": "v2"}]}, "tags": ["git", "reset"]}
{"id": "command_substitution", "request": "write today's date to today.txt", "setup": [], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "today.txt"}, {"type": "file_contains", "path": "today.txt", "value": "2026"}]}, "tags": ["shell", "substitution"]}
{"id": "conditional_chain", "request": "create directory 'out' and copy all .txt files into it", "setup": ["echo aaa > a.txt", "echo bbb > b.txt", "echo ccc > c.log"], "verify": {"type": "compound", "checks": [{"type": "dir_exists", "path": "out"}, {"type": "file_exists", "path": "out/a.txt"}, {"type": "file_exists", "path": "out/b.txt"}, {"type": "file_not_exists", "path": "out/c.log"}]}, "tags": ["shell", "chain"]}
{"id": "subshell_variable", "request": "count .c files in the current directory and save the count to count.txt", "setup": ["touch a.c", "touch b.c", "touch c.c", "touch d.txt"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "count.txt"}, {"type": "file_contains", "path": "count.txt", "value": "3"}]}, "tags": ["shell", "subshell"]}
{"id": "loop_add_prefix", "request": "add the prefix 'backup_' to all .txt files in the current directory", "setup": ["echo a > one.txt", "echo b > two.txt", "echo c > three.log"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "backup_one.txt"}, {"type": "file_exists", "path": "backup_two.txt"}, {"type": "file_not_exists", "path": "one.txt"}, {"type": "file_not_exists", "path": "two.txt"}, {"type": "file_exists", "path": "three.log"}]}, "tags": ["loop", "for", "rename"]}
{"id": "loop_add_extension", "request": "append '.bak' extension to every file in the current directory", "setup": ["echo x > alpha", "echo y > beta", "echo z > gamma"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "alpha.bak"}, {"type": "file_exists", "path": "beta.bak"}, {"type": "file_exists", "path": "gamma.bak"}]}, "tags": ["loop", "for", "rename"]}
{"id": "loop_uppercase_contents", "request": "convert the contents of every .txt file in the current directory to uppercase in-place", "setup": ["echo hello > a.txt", "echo world > b.txt"], "verify": {"type": "compound", "checks": [{"type": "file_contains", "path": "a.txt", "value": "HELLO"}, {"type": "file_contains", "path": "b.txt", "value": "WORLD"}]}, "tags": ["loop", "for", "tr", "sed"]}
{"id": "loop_number_lines", "request": "for each .txt file, prepend its line count to the filename (e.g. 3_data.txt)", "setup": ["printf 'a\\nb\\nc\\n' > data.txt", "printf 'x\\n' > short.txt"], "verify": {"type": "compound", "checks": [{"type": "file_exists", "path": "3_data.txt"}, {"type": "file_exists", "path": "1_short.txt"}]}, "tags": ["loop", "for", "wc", "rename"]}
{"id": "loop_split_file", "request": "split each line of input.txt into a separate file named line1.txt, line2.txt, etc.", "setup": ["printf 'alpha\\nbeta\\ngamma\\n' > input.txt"], "verify": {"type": "compound", "checks": [{"type": "file_contains", "path": "line1.txt", "value": "alpha"}, {"type": "file_contains", "path": "line2.txt", "value": "beta"}, {"type": "file_contains", "path": "line3.txt", "value": "gamma"}]}, "tags": ["loop", "while", "read"]}
{"id": "create_symlink", "request": "create a symbolic link a -> b", "setup": ["echo target_content > b"], "verify": {"type": "compound", "checks": [{"type": "symlink_target", "path": "a", "target": "b"}, {"type": "file_contains", "path": "a", "value": "target_content"}]}, "tags": ["file_ops", "ln"]}
{"id": "grep_regex_email", "request": "find all lines containing an email address in contacts.txt", "setup": ["printf 'John: john@example.com\\nPhone: 555-1234\\nJane: jane.doe@company.org\\nAddress: 123 Main St\\nBob: bob+tag@mail.co.uk\\n' > contacts.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "john@example.com"}, {"type": "stdout_contains", "value": "jane.doe@company.org"}, {"type": "stdout_contains", "value": "bob+tag@mail.co.uk"}, {"type": "stdout_not_contains", "value": "Phone"}, {"type": "stdout_not_contains", "value": "Address"}]}, "tags": ["text", "grep", "regex"]}
{"id": "grep_regex_ipv4", "request": "extract lines containing an IPv4 address from server.log", "setup": ["printf 'connected from 192.168.1.100\\nuser logged in\\ntimeout from 10.0.0.5\\nrestarting service\\nblocked 172.16.254.1\\n' > server.log"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "192.168.1.100"}, {"type": "stdout_contains", "value": "10.0.0.5"}, {"type": "stdout_contains", "value": "172.16.254.1"}, {"type": "stdout_not_contains", "value": "user logged in"}, {"type": "stdout_not_contains", "value": "restarting"}]}, "tags": ["text", "grep", "regex"]}
{"id": "grep_regex_start_anchor", "request": "show lines that start with a digit in report.txt", "setup": ["printf '1. Introduction\\nOverview of results\\n2. Methods\\nDetailed analysis\\n3. Conclusion\\nFinal remarks\\n' > report.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "1. Introduction"}, {"type": "stdout_contains", "value": "2. Methods"}, {"type": "stdout_contains", "value": "3. Conclusion"}, {"type": "stdout_not_contains", "value": "Overview"}, {"type": "stdout_not_contains", "value": "Detailed"}, {"type": "stdout_not_contains", "value": "Final"}]}, "tags": ["text", "grep", "regex"]}
{"id": "grep_regex_or_pattern", "request": "find lines containing either 'WARNING' or 'CRITICAL' in syslog.txt", "setup": ["printf 'INFO: system started\\nWARNING: disk usage 85%%\\nINFO: cron job completed\\nCRITICAL: out of memory\\nDEBUG: cache miss\\nWARNING: high latency\\n' > syslog.txt"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "WARNING: disk usage"}, {"type": "stdout_contains", "value": "CRITICAL: out of memory"}, {"type": "stdout_contains", "value": "WARNING: high latency"}, {"type": "stdout_not_contains", "value": "INFO"}, {"type": "stdout_not_contains", "value": "DEBUG"}]}, "tags": ["text", "grep", "regex"]}
{"id": "grep_regex_invert", "request": "show all lines in config.ini that are not blank and not comments starting with #", "setup": ["printf '# Database settings\\nhost=localhost\\nport=5432\\n\\n# Auth settings\\nuser=admin\\npassword=secret\\n\\n' > config.ini"], "verify": {"type": "compound", "checks": [{"type": "stdout_contains", "value": "host=localhost"}, {"type": "stdout_contains", "value": "port=5432"}, {"type": "stdout_contains", "value": "user=admin"}, {"type": "stdout_contains", "value": "password=secret"}, {"type": "stdout_not_contains", "value": "# Database"}, {"type": "stdout_not_contains", "value": "# Auth"}]}, "tags": ["text", "grep", "regex"]}
{"id": "today_yyyy_mm_dd", "request": "print today's date in YYYY-MM-DD format", "setup": [], "verify": {"type": "stdout_match", "pattern": "[0-9]{4}-[0-9]{2}-[0-9]{2}"}, "tags": ["system", "date", "format"]}
